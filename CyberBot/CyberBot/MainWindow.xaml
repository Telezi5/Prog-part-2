<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot"
        Height="600"
        Width="800"
        Background="#1a1a2e">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="CYBERBOT"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="#e94560"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Name Input Section -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,15">

            <TextBlock Text="Your Name:"
                       Foreground="White"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <TextBox x:Name="NameBox"
                     Width="200"
                     FontSize="16"
                     Padding="5"
                     Margin="5,0"/>

            <Button Content="Start Chat"
                    FontSize="16"
                    Padding="10,5"
                    Margin="10,0,0,0"
                    Background="#e94560"
                    Foreground="White"
                    BorderThickness="0"
                    Click="StartChat_Click"/>
        </StackPanel>

        <!-- Chat Bubble Area -->
        <Border Grid.Row="2"
                Background="#16213e"
                Margin="0,0,0,10"
                Padding="10">

            <ScrollViewer x:Name="ChatScroller"
                          VerticalScrollBarVisibility="Auto">

                <!-- Each chat message is added here as a styled Border -->
                <StackPanel x:Name="ChatPanel"
                            VerticalAlignment="Top"/>

            </ScrollViewer>
        </Border>

        <!-- Message Input Area -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal">

            <TextBox x:Name="UserInput"
                     Width="620"
                     FontSize="16"
                     Padding="8"
                     Background="#0f3460"
                     Foreground="White"
                     BorderBrush="#e94560"
                     KeyDown="UserInput_KeyDown"/>

            <Button Content="Send"
                    FontSize="16"
                    Padding="15,8"
                    Margin="10,0,0,0"
                    Background="#e94560"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SendMessage_Click"/>
        </StackPanel>

    </Grid>
</Window>
